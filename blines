local _farmConn=nil
local _farmTargetList={"-- None --"}
local _farmTargetMap={}
local _farmOffX = 0
local _farmOffY = 0
local _farmOffZ = 6.5
local _farmDE=game:GetService("ReplicatedStorage").Events.DataEvent

local function _scanFarmTargets()
    _farmTargetList={"-- None --",">> Nearest Mob <<"}
    _farmTargetMap={}
    local PS=game:GetService("Players")
    for _,obj in ipairs(_getMobs()) do
        do
            local hum=obj:FindFirstChildOfClass("Humanoid")
            local root=obj:FindFirstChild("HumanoidRootPart")
            if hum and hum.Health>0 and root then
                local label=obj.Name
                local n=0; local base=label
                while _farmTargetMap[label] do n=n+1; label=base.." ("..n..")" end
                table.insert(_farmTargetList,label)
                _farmTargetMap[label]=root
            end
        end
    end
    if Opt.FarmTarget then Opt.FarmTarget:SetValues(_farmTargetList);Opt.FarmTarget:SetValue("-- None --") end

end

GB.VVFarm:AddLabel("── Auto Farm ──")
GB.VVFarm:AddButton({ Text="Refresh Mobs", Func=_scanFarmTargets })
GB.VVFarm:AddDropdown("FarmTarget",{ Text="Target", Values=_farmTargetList, Default=1, Multi=false })
GB.VVFarm:AddToggle("AutoFarmBL",{ Text="Auto Farm", Default=false,
    Callback=function(p)
        if _farmConn then _farmConn:Disconnect(); _farmConn=nil end
        if not p then
            pcall(function() if sethiddenproperty then
                local hrp=LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
                if hrp then sethiddenproperty(hrp,"PhysicsRepRootPart",nil) end
            end end)
            return
        end
        local _auraTick=0
        _farmConn=RS.Heartbeat:Connect(function(dt)
            local char=LP.Character
            local hrp=char and char:FindFirstChild("HumanoidRootPart")
            if not hrp then return end
            local val=Opt.FarmTarget and Opt.FarmTarget.Value
            local sel=type(val)=="table" and next(val) or val
            if not sel or sel=="-- None --" then return end
            local root
            if sel==">> Nearest Mob <<" then
                local best,bestDist=nil,math.huge
                local PS2=game:GetService("Players")
                for _,obj in ipairs(workspace:GetChildren()) do
                    if obj:IsA("Model") and not PS2:GetPlayerFromCharacter(obj) then
                        local h=obj:FindFirstChildOfClass("Humanoid")
                        local r=obj:FindFirstChild("HumanoidRootPart")
                        if h and h.Health>0 and r then
                            local d=(r.Position-hrp.Position).Magnitude
                            if d<bestDist then best=r; bestDist=d end
                        end
                    end
                end
                root=best
            else
                root=_farmTargetMap[sel]
                if not root or not root.Parent then _farmTargetMap[sel]=nil; return end
            end
            if not root then return end
            local hum=root.Parent:FindFirstChildOfClass("Humanoid")
            if not hum or hum.Health<=0 then return end
            local mobPos=root.Position
            -- lock position every frame so physics cant drift
            local _fmode=Opt.FarmMode and (type(Opt.FarmMode.Value)=="table" and next(Opt.FarmMode.Value) or Opt.FarmMode.Value) or "Above"
            local _fpos
            if _fmode=="Above" then
                _fpos=Vector3.new(mobPos.X + _farmOffX, mobPos.Y + _farmOffZ + _farmOffY, mobPos.Z)
            elseif _fmode=="Below" then
                _fpos=Vector3.new(mobPos.X + _farmOffX, mobPos.Y - _farmOffZ + _farmOffY, mobPos.Z)
            elseif _fmode=="In Front" then
                local look=root.CFrame.LookVector
                _fpos=mobPos + look * _farmOffZ + Vector3.new(_farmOffX, _farmOffY, 0)
            elseif _fmode=="Behind" then
                local look=root.CFrame.LookVector
                _fpos=mobPos - look * _farmOffZ + Vector3.new(_farmOffX, _farmOffY, 0)
            else
                _fpos=Vector3.new(mobPos.X + _farmOffX, mobPos.Y + _farmOffZ + _farmOffY, mobPos.Z)
            end
            hrp.CFrame=CFrame.lookAt(_fpos, mobPos)
            hrp.AssemblyLinearVelocity=Vector3.zero
            hrp.AssemblyAngularVelocity=Vector3.zero
            pcall(function()
                if sethiddenproperty then
                    sethiddenproperty(hrp,"PhysicsRepRootPart",root)
                end
                root.AssemblyLinearVelocity=Vector3.zero
                root.AssemblyAngularVelocity=Vector3.zero
            end)
            -- throttle kill aura to ~10hz only
            _auraTick=_auraTick+dt
            if _auraTick>=0.1 then
                _auraTick=0
                pcall(function() _farmDE:FireServer("CheckMeleeHit",nil,"NormalAttack",false) end)
            end
        end)
    end,
})

