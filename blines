-- Parry logic
local parryCD=false
local Events2=game:GetService("ReplicatedStorage"):WaitForChild("Events",10)
local DF2=Events2 and Events2:WaitForChild("DataFunction",5)
local DE2=Events2 and Events2:WaitForChild("DataEvent",5)
local function rtt() local n=game:GetService("Stats"):FindFirstChild("Network");local s=n and n:FindFirstChild("ServerStatsItem");local d=s and s:FindFirstChild("Data Ping");return d and d:GetValue()/1000 or 0.05 end
local function stL(c) return string.lower(tostring(c and c:GetAttribute("CurrentState") or "")) end
local function sBlock(st) pcall(function() if st then DF2:InvokeServer("Block") else DF2:InvokeServer("EndBlock") end end) end
local function sDodge2() pcall(function() DE2:FireServer("Dash") end) end
local function sParry()
    if parryCD then return false end
    parryCD = true
    task.delay(0.5, function() parryCD = false end)
    sBlock(true)
    task.delay(0.3 + rtt(), function() sBlock(false) end)
    return true
end
local function cParry() return (os.clock()-lastParry)>=0.12 and not parryCD end
local function cDodge2() return (os.clock()-lastDodge)>=1.75 and LP.Character~=nil end
local function doParry()
    if not Tog.AutoParry or not Tog.AutoParry.Value then return end
    if cParry() then if sParry() then lastParry=os.clock() end
    elseif cDodge2() then sDodge2();lastDodge=os.clock() end
end
local function distTo2(root) local c=LP.Character;if not c then return nil end;local r=c:FindFirstChild("HumanoidRootPart");if not r or not root then return nil end;return(r.Position-root.Position).Magnitude end

local function doLogAnim(id,src,dist,entityRef,animName)
    if not Tog.EnableLogger or not Tog.EnableLogger.Value then return end
    local numId=id:match("%?id=(%d+)") or id:match("rbxassetid://(%d+)") or id:match("^(%d+)$")
    if numId then id="rbxassetid://"..numId end
    if id==""or id=="rbxassetid://0" then return end
    local maxR=Opt.LogRadius and Opt.LogRadius.Value or 100
    if dist and dist>maxR then return end
    local mapKey=id.."|"..(src or "")
    if loggedMap[mapKey] then return end;loggedMap[mapKey]=true
    local entry={id=id,source=src or "Unknown",dist=dist,cat="Characters",entity=entityRef,animName=animName}
    table.insert(loggedAnims,1,entry)
    if #loggedAnims>120 then local old=loggedAnims[#loggedAnims];loggedMap[(old.id or "").."|"..(old.source or "")]=nil;table.remove(loggedAnims) end
    if logWin.Visible then addLine(entry) end
end

