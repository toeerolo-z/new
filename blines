-- ── Mob Cache (performance) ──────────────────────────────────────────────────
local _mobCache = {}
local function _isMob(obj)
    if not obj:IsA("Model") then return false end
    if PS:GetPlayerFromCharacter(obj) then return false end
    local hum=obj:FindFirstChildOfClass("Humanoid")
    return hum and hum.Health > 0
end
-- populate cache on load
for _,obj in ipairs(workspace:GetChildren()) do
    if _isMob(obj) then _mobCache[obj]=true end
end
-- keep cache live
workspace.ChildAdded:Connect(function(obj)
    if _isMob(obj) then _mobCache[obj]=true end
end)
workspace.ChildRemoved:Connect(function(obj)
    _mobCache[obj]=nil
end)
-- helper: iterate live mobs only
local function _getMobs()
    local t={}
    for obj in pairs(_mobCache) do
        local hum=obj:FindFirstChildOfClass("Humanoid")
        if obj.Parent and hum and hum.Health>0 then
            table.insert(t,obj)
        else
            _mobCache[obj]=nil -- evict dead/removed
        end
    end
    return t
end

