local function _refreshFruits()
    _fruitDropList={"-- None --"}
    local seen={}
    for _,obj in ipairs(workspace:GetChildren()) do
        if obj:IsA("Model") and obj.Name:sub(1,4)=="Tree" then
            local ft=obj:FindFirstChild("FruitType")
            if ft and not seen[ft.Value] then
                seen[ft.Value]=true
                table.insert(_fruitDropList, ft.Value)
            end
        end
